Vagrant.configure("2") do |config|
  config.vm.box = "ubuntu/jammy64"
  config.vm.boot_timeout = 600

  # Topology (full mesh):
  #
  #   r1 (AS65001) ---eth1--- r2 (AS65002)
  #      |  \              /    |
  #    eth2                    eth2
  #      |  /              \    |
  #   r4 (AS65004) ---eth1--- r3 (AS65003)
  #
  # Point-to-point links (last octet = router# + 1):
  #   10.0.12.0/24  r1(.2) <-> r2(.3)
  #   10.0.23.0/24  r2(.3) <-> r3(.4)
  #   10.0.34.0/24  r3(.4) <-> r4(.5)
  #   10.0.14.0/24  r1(.2) <-> r4(.5)

  # Shared FRR provisioning script
  $frr_install = <<-SCRIPT
    export DEBIAN_FRONTEND=noninteractive
    curl -s https://deb.frrouting.org/frr/keys.gpg | sudo tee /usr/share/keyrings/frrouting.gpg > /dev/null
    FRRVER="frr-stable"
    echo "deb [signed-by=/usr/share/keyrings/frrouting.gpg] https://deb.frrouting.org/frr $(lsb_release -s -c) $FRRVER" | sudo tee /etc/apt/sources.list.d/frr.list
    sudo apt-get update -qq
    sudo apt-get install -y -qq frr frr-pythontools
    sudo sed -i 's/^bgpd=no/bgpd=yes/' /etc/frr/daemons
    sudo systemctl restart frr
  SCRIPT

  # Enable IP forwarding
  $enable_forwarding = <<-SCRIPT
    sudo sysctl -w net.ipv4.ip_forward=1
    echo "net.ipv4.ip_forward=1" | sudo tee -a /etc/sysctl.conf
  SCRIPT

  # AS 65001 — Router 1
  config.vm.define "r1" do |r1|
    r1.vm.hostname = "r1"

    r1.vm.network "private_network",
      ip: "10.0.12.2",
      virtualbox__intnet: "link_r1_r2"

    r1.vm.network "private_network",
      ip: "10.0.13.2",
      virtualbox__intnet: "link_r1_r3"

    r1.vm.network "private_network",
      ip: "10.0.14.2",
      virtualbox__intnet: "link_r1_r4"    

    r1.vm.provider "virtualbox" do |vb|
      vb.name = "lab2-r1-as65001"
      vb.memory = "512"
      vb.cpus = 1
    end

    r1.vm.provision "shell", inline: $enable_forwarding
    r1.vm.provision "shell", inline: $frr_install
  end

  # AS 65002 — Router 2
  config.vm.define "r2" do |r2|
    r2.vm.hostname = "r2"

    r2.vm.network "private_network",
      ip: "10.0.12.3",
      virtualbox__intnet: "link_r1_r2"

    r2.vm.network "private_network",
      ip: "10.0.23.3",
      virtualbox__intnet: "link_r2_r3"

    r2.vm.network "private_network",
      ip: "10.0.24.3",
      virtualbox__intnet: "link_r2_r4"

    r2.vm.provider "virtualbox" do |vb|
      vb.name = "lab2-r2-as65002"
      vb.memory = "512"
      vb.cpus = 1
    end

    r2.vm.provision "shell", inline: $enable_forwarding
    r2.vm.provision "shell", inline: $frr_install
  end

  # AS 65003 — Router 3
  config.vm.define "r3" do |r3|
    r3.vm.hostname = "r3"

    r3.vm.network "private_network",
      ip: "10.0.13.4",
      virtualbox__intnet: "link_r1_r3"

    r3.vm.network "private_network",
      ip: "10.0.23.4",
      virtualbox__intnet: "link_r2_r3"

    r3.vm.network "private_network",
      ip: "10.0.34.4",
      virtualbox__intnet: "link_r3_r4"

    r3.vm.provider "virtualbox" do |vb|
      vb.name = "lab2-r3-as65003"
      vb.memory = "512"
      vb.cpus = 1
    end

    r3.vm.provision "shell", inline: $enable_forwarding
    r3.vm.provision "shell", inline: $frr_install
  end

  # AS 65004 — Router 4
  config.vm.define "r4" do |r4|
    r4.vm.hostname = "r4"

    r4.vm.network "private_network",
      ip: "10.0.14.5",
      virtualbox__intnet: "link_r1_r4"

    r4.vm.network "private_network",
      ip: "10.0.24.5",
      virtualbox__intnet: "link_r2_r4"

    r4.vm.network "private_network",
      ip: "10.0.34.5",
      virtualbox__intnet: "link_r3_r4"

    r4.vm.provider "virtualbox" do |vb|
      vb.name = "lab2-r4-as65004"
      vb.memory = "512"
      vb.cpus = 1
    end

    r4.vm.provision "shell", inline: $enable_forwarding
    r4.vm.provision "shell", inline: $frr_install
  end
end
